# Utviklings-Dockerfile med Hot Module Replacement

# Basis-stadium for utvikling
FROM node:22-alpine AS base

WORKDIR /app

# Installer nodemon globalt for backend hot reload
RUN npm install -g nodemon

# Frontend Utviklings-stadium
FROM base AS frontend

# Kopier pakkefiler
COPY package*.json ./

# Installer frontend-avhengigheter
RUN npm ci

# Kopier alle kildefiler for volume mounting
COPY . .

# Eksponer Vite dev server port
EXPOSE 5173

# Start Vite utviklingsserver med HMR
CMD ["npm", "run", "dev"]

# Backend Utviklings-stadium  
FROM base AS backend

WORKDIR /app

# Kopier backend pakkefiler
COPY server/package*.json ./server/

# Installer backend-avhengigheter inkludert dev-avhengigheter for nodemon
RUN cd server && npm ci

# Kopier backend kildefiler
COPY server/ ./server/

# Kopier rot package.json for skripter
COPY package*.json ./

# Ekpose backend port
EXPOSE 6768

# Start backend med nodemon for hot reload
CMD ["sh", "-c", "cd server && npm run dev"]
