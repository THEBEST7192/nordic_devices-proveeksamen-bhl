# PostgreSQL Passord
DB_PASSWORD=ditt_sterke_passord_her
# Krypteringsnøkkel Konfigurasjon
# Generer med: openssl rand -base64 32 (Linux/macOS/WSL)
MESSAGE_ENCRYPTION_KEY=din_base64_krypteringsnøkkel_her
# Data Retention (brukes av frontend og backend)
RESERVATION_RETENTION_DAYS=1
# Frontend API URL
VITE_API_URL=http://host.docker.internal:6767
# Cloudflare Tunnel Token
# Få token fra: Zero Trust > Networks > Manage Tunnel > Add a Tunnel
CLOUDFLARE_TUNNEL_TOKEN=din_cloudflare_tunnel_token_her
